{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["tests/**/*.test.ts"],
  "project": ["src/**/*.ts", "tests/**/*.ts"],
  "ignore": ["tests/fixtures/**"],
  "ignoreDependencies": [
    "@commitlint/cli",
    "@simple-release/npm",
    "conventional-changelog-angular"
  ],
  "ignoreBinaries": ["tsc"],
  "ignoreExportsUsedInFile": true,
  "tags": ["-internal"]
}

{
  "attribution": { "commit": "", "pr": "" },
  "permissions": {
    "allow": [
      "Bash(oxfmt *)",
      "Bash(oxlint *)",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(bun install *)",
      "Bash(git *)",
      "Bash(wc *)",
      "Bash(ls *)",
      "Bash(rm *)",
      "Bash(proto *)",
      "Skill(archgate:reviewer)",
      "Skill(archgate:lessons-learned)",
      "Skill(archgate:adr-author)",
      "WebSearch",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run format:file \"$(jq -r .tool_input.file_path)\""
          }
        ]
      }
    ]
  },
  "agent": "archgate:developer"
}

{
  "attribution": { "commit": "", "pr": "" },
  "permissions": {
    "allow": [
      "Bash(oxfmt *)",
      "Bash(oxlint *)",
      "Bash(bun run *)",
      "Bash(bun test *)",
      "Bash(bun install *)",
      "Bash(git *)",
      "Bash(wc *)",
      "Bash(ls *)",
      "Bash(rm *)",
      "Bash(proto *)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs -I {} oxfmt --write {}"
          }
        ]
      }
    ]
  },
  "enabledPlugins": { "sentry@claude-plugins-official": true }
}

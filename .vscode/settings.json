{
  "[css]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[html]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[javascript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[json]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[less]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[markdown]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[mdx]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[typescript]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[xml]": { "editor.defaultFormatter": "oxc.oxc-vscode" },
  "[yaml]": { "editor.defaultFormatter": "redhat.vscode-yaml" },
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.linkedEditing": true,
  "editor.tabSize": 2,
  "git.autofetch": true,
  "git.blame.editorDecoration.enabled": true,
  "git.confirmSync": false,
  "js/ts.format.enabled": false,
  "js/ts.implementationsCodeLens.enabled": false,
  "js/ts.implementationsCodeLens.showOnInterfaceMethods": false,
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.variableTypes.enabled": true,
  "js/ts.locale": "en",
  "js/ts.preferences.importModuleSpecifier": "project-relative",
  "js/ts.tsc.autoDetect": "off",
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.tsserver.automaticTypeAcquisition.enabled": false,
  "js/ts.tsserver.checkNpmIsInstalled": false,
  "js/ts.tsserver.maxMemory": 16384,
  "js/ts.tsserver.node.path": "node",
  "oxc.enable": true,
  "oxc.enable.oxfmt": true,
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "oxc.path.node": "node",
  "redhat.telemetry.enabled": false,
  "telemetry.telemetryLevel": "off",
  "telemetry.feedback.enabled": false,
  "telemetry.editStats.enabled": false,
  "dotnetAcquisitionExtension.enableTelemetry": false,
  "terminal.integrated.scrollback": 100000,
  "oxc.path.oxfmt": "node_modules\\oxfmt\\bin\\oxfmt",
  "oxc.path.oxlint": "node_modules\\oxlint\\bin\\oxlint"
}
